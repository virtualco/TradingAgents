# ═══════════════════════════════════════════════════════════════════════════════
# TradingAgents Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials:
#   cp deploy/.env.template deploy/.env
# ═══════════════════════════════════════════════════════════════════════════════

# Bybit Testnet API credentials (https://testnet.bybit.com → API Management)
BYBIT_TESTNET_API_KEY=your_api_key_here
BYBIT_TESTNET_API_SECRET=your_api_secret_here

# Dashboard endpoint (your deployed Manus dashboard URL)
DASHBOARD_URL=https://tradingdash-dyvbtahs.manus.space
DASHBOARD_CRON_COOKIE=your_cron_cookie_here

# Forge API (for LLM-based re-optimisation, optional)
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here

# Metrics server port (exposed to dashboard for LIVE mode)
METRICS_PORT=8765

# Trading symbols (comma-separated, 8 crypto symbols)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,AVAXUSDT,DOGEUSDT,BNBUSDT,XRPUSDT,LINKUSDT

# Risk management
MAX_POSITION_USD=100
TRADING_CAPITAL_USDT=10000
TRADING_MAX_POS_PCT=0.02
TRADING_DAILY_LOSS_LIM=0.03
DRY_RUN=false

# ML Regime Model (auto-detected from data/models/ if not set)
# REGIME_MODEL_PATH=/opt/trading-agents/data/models/regime_gbm_v1.joblib
