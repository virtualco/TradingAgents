# ============================================================
# TradingAgents — Bybit Live Trading Configuration
# Copy to .env.bybit and fill in your values.
# NEVER commit .env.bybit to git.
# ============================================================

# ── Bybit API Credentials ────────────────────────────────────
# Testnet keys: https://testnet.bybit.com/app/user/api-management
# Mainnet keys: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Set to "false" for LIVE MAINNET trading (real money!)
BYBIT_TESTNET=true

# ── Trading Parameters ───────────────────────────────────────
# Symbols to trade (comma-separated Bybit linear perpetual symbols)
TRADING_SYMBOLS=BTCUSDT,ETHUSDT

# Candle interval in minutes (must be one of: 1,3,5,15,30,60,120,240,360,720)
TRADING_INTERVAL=60

# Capital allocation per symbol in USDT
TRADING_CAPITAL_USDT=1000

# Maximum concurrent open positions
TRADING_MAX_POSITIONS=2

# Maximum daily drawdown % before circuit breaker halts trading
TRADING_MAX_DD_PCT=5.0

# ── Safety Flags ─────────────────────────────────────────────
# Set to "true" to generate signals but NOT place real orders
TRADING_DRY_RUN=true

# ── System ───────────────────────────────────────────────────
TRADING_LOG_LEVEL=INFO
TRADING_STATE_DB=data/live_trading.db
TRADING_METRICS_PORT=8765
